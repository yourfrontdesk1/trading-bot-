# Copy this file to .env and fill in your keys.
# PAPER mode uses fake money — safe to run without real risk.

# --- Alpaca (stocks) ---
# Get free paper-trading keys at https://app.alpaca.markets/ (Paper Trading -> API Keys)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# true = paper/fake money, false = LIVE real money
ALPACA_PAPER=true

# --- Polymarket (prediction markets) ---
# Reads are public and need no key. Placing trades needs a wallet key (add later).
POLYMARKET_WALLET_KEY=

# --- Bot behaviour ---
# DRY_RUN=true logs intended trades but does NOT place them anywhere.
DRY_RUN=true
# Seconds between each check of the market
POLL_SECONDS=60
